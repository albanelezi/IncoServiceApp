{
  "hosting": {
    "site": "incoservice-4e196",
    "public": ".",
    "ignore": [
      "firebase.json",
      "**/.*",
      "**/node_modules/**",
      "functions/**",
      "bundle-worker.js",
      "optimizer-worker.js",
      "optimizer-worker.min.js",
      "optimizer-worker.obf.js",
      "INCO_Furniture_v12.src.html",
      "firestore.rules",
      "README.md",
      "*.zip",
      "*.bak",
      "_*.js"
    ],
    "rewrites": [
      { "source": "**", "destination": "/INCO_Furniture_v12.html" }
    ]
  },
  "functions": [
    {
      "source": "functions",
      "codebase": "default",
      "ignore": [
        "node_modules",
        ".git",
        "firebase-debug.log",
        "firebase-debug.*.log",
        "_*.js",
        "test-*.js",
        "verify-*.js"
      ]
    }
  ],
  "firestore": {
    "rules": "firestore.rules"
  }
}
